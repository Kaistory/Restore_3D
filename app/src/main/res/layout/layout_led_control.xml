<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/ledControlLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvBleStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="BLE: Chưa kết nối"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/btnConnectBle" />

    <Button
        android:id="@+id/btnConnectBle"
        android:layout_width="wrap_content"
        android:layout_height="50dp"
        android:text="Kết nối ESP32"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="@+id/tvBleStatus" />

    <FrameLayout
        android:id="@+id/led_visualizer_container"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_marginTop="32dp"
        android:background="#1A000000"
        app:layout_constraintTop_toBottomOf="@+id/btnConnectBle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
    </FrameLayout>

    <LinearLayout
        android:id="@+id/controlPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@+id/led_visualizer_container"
        tools:layout_editor_absoluteX="-113dp">

        <Button
            android:id="@+id/btnLaunchPS"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Photometric Stereo (Chụp + Dự đoán Normal Map)"
            android:textAllCaps="false"
            android:textStyle="bold" />

        <!--        <include layout="@layout/item_slider_red" />-->
        <!--        <include layout="@layout/item_slider_green" />-->
        <!--        <include layout="@layout/item_slider_blue" />-->
        <!--        <include layout="@layout/item_slider_brightness" />-->
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@+id/controlPanel">

        <Button android:id="@+id/btnSaveMode" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Lưu" />
        <Button android:id="@+id/btnImport" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="8dp" android:text="Import" />
        <Button android:id="@+id/btnExport" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="8dp" android:text="Export" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>